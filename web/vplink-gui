#!/bin/bash
# ═══════════════════════════════════════════════════════════════
#  VPLINK-GUI — Web Control Center Launcher
#  Single server: serves API + frontend on one port
# ═══════════════════════════════════════════════════════════════
set -euo pipefail

VPLINK_HOME="${VPLINK_HOME:-$HOME/.vplink247}"
WEB_DIR="$VPLINK_HOME/web"
PORT="${VPLINK_PORT:-5173}"

GREEN='\033[0;32m'; CYAN='\033[0;36m'; BOLD='\033[1m'; DIM='\033[2m'; NC='\033[0m'

# ── Parse args (before install check so --help works) ─
case "${1:-}" in
  --help|-h)
    echo "VPLINK-GUI — VPLink Web Control Center"
    echo ""
    echo "Usage: vplink-gui [options]"
    echo ""
    echo "Options:"
    echo "  --port PORT     Port to serve on (default: 5173)"
    echo "  --no-browser    Don't open browser"
    echo "  --help          Show this help"
    echo ""
    echo "Environment:"
    echo "  VPLINK_PORT       Server port (default: 5173)"
    echo "  VPLINK_HOME       Config directory (default: ~/.vplink247)"
    exit 0
    ;;
  --version|-v)
    echo "VPLINK-GUI v3.0"
    exit 0
    ;;
esac

NO_BROWSER=false
while [[ $# -gt 0 ]]; do
  case "$1" in
    --port) PORT="$2"; shift 2 ;;
    --no-browser) NO_BROWSER=true; shift ;;
    *) shift ;;
  esac
done

# ── Check installation ────────────────────────────────
if [ ! -d "$WEB_DIR" ]; then
  echo "VPLink GUI not installed. Run the installer first:"
  echo "  curl -fsSL https://raw.githubusercontent.com/adittaya/workflow-vplink/main/install.sh | bash"
  exit 1
fi

# ── Check dist exists ─────────────────────────────────
DIST_DIR="$WEB_DIR/client/dist"
if [ ! -d "$DIST_DIR" ] || [ ! -f "$DIST_DIR/index.html" ]; then
  echo "Frontend not built. Run installer or build manually:"
  echo "  cd ~/.vplink247/web/client && npm install && npx vite build"
  exit 1
fi

# ── Kill existing instances ───────────────────────────
pkill -f "python3.*web/server/app.py" 2>/dev/null || true
sleep 0.5

# ── Start server ──────────────────────────────────────
echo -e "${DIM}Starting VPLink Control Center on port $PORT...${NC}"
VPLINK_HOME="$VPLINK_HOME" VPLINK_WEB_PORT=$PORT python3 "$WEB_DIR/server/app.py" &
SERVER_PID=$!
sleep 1

# Verify
if ! curl -s "http://localhost:$PORT/api/health" >/dev/null 2>&1; then
  echo "Server failed to start on port $PORT"
  kill $SERVER_PID 2>/dev/null
  exit 1
fi

# ── Print info ────────────────────────────────────────
LOCAL_IP=$(hostname -I 2>/dev/null | awk '{print $1}' || echo "localhost")

echo ""
echo -e "${BOLD}╔══════════════════════════════════════════════════════════╗${NC}"
echo -e "${BOLD}║          ⚡ VPLink Control Center v3.0                  ║${NC}"
echo -e "${BOLD}╠══════════════════════════════════════════════════════════╣${NC}"
echo -e "${BOLD}║                                                          ║${NC}"
echo -e "${BOLD}║  Local:   ${CYAN}http://localhost:$PORT${NC}${BOLD}                          ║${NC}"
echo -e "${BOLD}║  Network: ${CYAN}http://$LOCAL_IP:$PORT${NC}${BOLD}                      ║${NC}"
echo -e "${BOLD}║                                                          ║${NC}"
echo -e "${BOLD}║  ${DIM}Press Ctrl+C to stop${NC}${BOLD}                                  ║${NC}"
echo -e "${BOLD}║                                                          ║${NC}"
echo -e "${BOLD}╚══════════════════════════════════════════════════════════╝${NC}"
echo ""

# ── Open browser ──────────────────────────────────────
if [ "$NO_BROWSER" = false ]; then
  URL="http://localhost:$PORT"
  if command -v xdg-open &>/dev/null; then
    xdg-open "$URL" 2>/dev/null &
  elif command -v open &>/dev/null; then
    open "$URL" 2>/dev/null &
  elif command -v wslview &>/dev/null; then
    wslview "$URL" 2>/dev/null &
  fi
fi

# ── Cleanup on exit ───────────────────────────────────
cleanup() {
  echo ""
  echo -e "${DIM}Shutting down...${NC}"
  kill $SERVER_PID 2>/dev/null
  wait $SERVER_PID 2>/dev/null
  echo -e "${GREEN}Stopped.${NC}"
}
trap cleanup EXIT INT TERM

wait
