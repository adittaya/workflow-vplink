#!/bin/bash
# ═══════════════════════════════════════════════════════════════
#  VPLINK-GUI — Web Control Center Launcher
#  Starts API server + serves frontend, opens browser
# ═══════════════════════════════════════════════════════════════
set -euo pipefail

VPLINK_HOME="${VPLINK_HOME:-$HOME/.vplink247}"
WEB_DIR="$VPLINK_HOME/web"
API_PORT="${VPLINK_API_PORT:-5180}"
WEB_PORT="${VPLINK_WEB_PORT:-5173}"
NO_BROWSER=false

GREEN='\033[0;32m'; CYAN='\033[0;36m'; BOLD='\033[1m'; DIM='\033[2m'; NC='\033[0m'

# ── Parse args (before install check so --help works) ─
case "${1:-}" in
  --help|-h)
    echo "VPLINK-GUI — VPLink Web Control Center"
    echo ""
    echo "Usage: vplink-gui [options]"
    echo ""
    echo "Options:"
    echo "  --port PORT     Web UI port (default: 5173)"
    echo "  --api-port PORT API server port (default: 5180)"
    echo "  --no-browser    Don't open browser"
    echo "  --help          Show this help"
    echo ""
    echo "Environment:"
    echo "  VPLINK_WEB_PORT   Frontend port (default: 5173)"
    echo "  VPLINK_API_PORT   API server port (default: 5180)"
    echo "  VPLINK_HOME       Config directory (default: ~/.vplink247)"
    exit 0
    ;;
  --version|-v)
    echo "VPLINK-GUI v3.0"
    exit 0
    ;;
esac

while [[ $# -gt 0 ]]; do
  case "$1" in
    --port) WEB_PORT="$2"; shift 2 ;;
    --api-port) API_PORT="$2"; shift 2 ;;
    --no-browser) NO_BROWSER=true; shift ;;
    *) shift ;;
  esac
done

# ── Check installation ────────────────────────────────
if [ ! -d "$WEB_DIR" ]; then
  echo "VPLink GUI not installed. Run the installer first:"
  echo "  curl -fsSL https://raw.githubusercontent.com/adittaya/workflow-vplink/main/install.sh | bash"
  exit 1
fi

# ── Kill existing instances ───────────────────────────
pkill -f "python3.*web/server/app.py" 2>/dev/null || true
pkill -f "python3 -m http.server $WEB_PORT" 2>/dev/null || true
sleep 0.5

# ── Start API server ──────────────────────────────────
echo -e "${DIM}Starting API server on port $API_PORT...${NC}"
VPLINK_WEB_PORT=$API_PORT python3 "$WEB_DIR/server/app.py" &
API_PID=$!
sleep 1

if ! curl -s "http://localhost:$API_PORT/api/health" >/dev/null 2>&1; then
  echo "API server failed to start on port $API_PORT"
  kill $API_PID 2>/dev/null
  exit 1
fi

# ── Serve frontend ────────────────────────────────────
DIST_DIR="$WEB_DIR/client/dist"
if [ ! -d "$DIST_DIR" ] || [ ! -f "$DIST_DIR/index.html" ]; then
  echo "Frontend not built. Run installer or build manually:"
  echo "  cd ~/.vplink247/web/client && npm install && npx vite build"
  kill $API_PID 2>/dev/null
  exit 1
fi

echo -e "${DIM}Serving frontend on port $WEB_PORT...${NC}"
(cd "$DIST_DIR" && python3 -m http.server "$WEB_PORT" --bind 0.0.0.0) &
WEB_PID=$!
sleep 0.5

# ── Print info ────────────────────────────────────────
LOCAL_IP=$(hostname -I 2>/dev/null | awk '{print $1}' || echo "localhost")

echo ""
echo -e "${BOLD}╔══════════════════════════════════════════════════════════╗${NC}"
echo -e "${BOLD}║          ⚡ VPLink Control Center v3.0                  ║${NC}"
echo -e "${BOLD}╠══════════════════════════════════════════════════════════╣${NC}"
echo -e "${BOLD}║                                                          ║${NC}"
echo -e "${BOLD}║  Local:   ${CYAN}http://localhost:$WEB_PORT${NC}${BOLD}                      ║${NC}"
echo -e "${BOLD}║  Network: ${CYAN}http://$LOCAL_IP:$WEB_PORT${NC}${BOLD}                  ║${NC}"
echo -e "${BOLD}║  API:     ${DIM}http://localhost:$API_PORT${NC}${BOLD}                       ║${NC}"
echo -e "${BOLD}║                                                          ║${NC}"
echo -e "${BOLD}║  ${DIM}Press Ctrl+C to stop${NC}${BOLD}                                  ║${NC}"
echo -e "${BOLD}║                                                          ║${NC}"
echo -e "${BOLD}╚══════════════════════════════════════════════════════════╝${NC}"
echo ""

# ── Open browser ──────────────────────────────────────
if [ "$NO_BROWSER" = false ]; then
  URL="http://localhost:$WEB_PORT"
  if command -v xdg-open &>/dev/null; then
    xdg-open "$URL" 2>/dev/null &
  elif command -v open &>/dev/null; then
    open "$URL" 2>/dev/null &
  elif command -v wslview &>/dev/null; then
    wslview "$URL" 2>/dev/null &
  fi
fi

# ── Cleanup on exit ───────────────────────────────────
cleanup() {
  echo ""
  echo -e "${DIM}Shutting down...${NC}"
  kill $API_PID $WEB_PID 2>/dev/null
  wait $API_PID $WEB_PID 2>/dev/null
  echo -e "${GREEN}Stopped.${NC}"
}
trap cleanup EXIT INT TERM

wait
